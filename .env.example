# Token do bot criado com o @BotFather no Telegram
TELEGRAM_BOT_TOKEN=123456789:AAAA...

# === IA para ler as notas fiscais: configure UMA das duas chaves ===

# Opção GRATUITA: Google Gemini. Gere a chave em https://aistudio.google.com/
# (a camada gratuita dá centenas de leituras por dia — de sobra para uso pessoal)
GEMINI_API_KEY=

# Opção paga (melhor qualidade de leitura): Anthropic Claude
# https://platform.claude.com/
ANTHROPIC_API_KEY=

# Opcional: força o provedor quando as duas chaves estão preenchidas
# (valores: gemini | claude — padrão: claude se as duas existirem)
IA_PROVIDER=

# Opcional: modelo do Gemini (padrão: gemini-2.5-flash)
GEMINI_MODEL=

# Opcional: restringe o bot a estes IDs de usuário do Telegram (separados por vírgula).
# Recomendado, já que os dados são financeiros. Descubra seu ID com o bot @userinfobot.
ALLOWED_USER_IDS=

# Opcional: fuso horário para resumos e lembretes (padrão: America/Sao_Paulo)
TIMEZONE=America/Sao_Paulo

# Opcional: caminho do banco de dados (padrão: data/financeiro.db)
DB_PATH=

# Opcional: modo "casal" — associa cada ID do Telegram a uma pessoa, para
# separar gastos por responsável e registrar a renda de cada um (/renda 1 ...,
# /renda 2 ...). Deixe em branco para usar o bot sem essa separação.
PESSOA_1_ID=
PESSOA_1_NOME=
PESSOA_2_ID=
PESSOA_2_NOME=
